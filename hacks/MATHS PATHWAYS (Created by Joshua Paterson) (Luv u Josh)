javascript:(function(){if(window.AutoCycleLoaded){return;}window.AutoCycleLoaded=true;var panel=document.createElement('div');panel.style.cssText='position: fixed; top: 12px; right: 12px; z-index: 999999; background: #1e1e1e; color: #eee; font: 12px/1.4 monospace; padding: 10px; border-radius: 8px; width: 220px; box-shadow: 0 2px 10px rgba(0,0,0,.4);';panel.innerHTML='<div style="font-weight:bold; margin-bottom:6px;">Auto Cycle</div><button id="ac-toggle" style="width:100%; padding:6px; cursor:pointer; margin-bottom:6px;">Start</button><div id="ac-status" style="color:#9cdcfe;">Idle</div><div id="ac-log" style="max-height:100px; overflow-y:auto; margin-top:6px; font-size:11px; color:#aaa;"></div><button id="ac-close" style="width:100%; padding:4px; cursor:pointer; margin-top:6px; background:rgba(255,50,50,0.4); border:none; color:#fff; border-radius:4px;">Close</button>';document.body.appendChild(panel);var toggleBtn=panel.querySelector('#ac-toggle');var statusEl=panel.querySelector('#ac-status');var logEl=panel.querySelector('#ac-log');var closeBtn=panel.querySelector('#ac-close');var running=false;var cycleTimeout1,cycleTimeout2,intervalId;function log(msg){var line=document.createElement('div');line.textContent=new Date().toLocaleTimeString()+' — '+msg;logEl.prepend(line);while(logEl.children.length>20){logEl.removeChild(logEl.lastChild);}}function setStatus(text){statusEl.textContent=text;}function runCycle(){if(!running)return;var app=document.querySelector('app')||document;var fullscreenBtn=[...document.querySelectorAll('button')].find(function(el){return el.innerText&&el.innerText.trim()==='Enable fullscreen';});if(fullscreenBtn){fullscreenBtn.click();log('Clicked: Enable fullscreen');}setStatus('Waiting to check answer...');cycleTimeout1=setTimeout(function(){if(!running)return;var checkBtn=[...app.querySelectorAll('div.check-button')].find(function(el){return el.innerText&&el.innerText.trim()==='Check my answer';});if(checkBtn){checkBtn.click();log('Clicked: Check my answer');}setStatus('Waiting to complete question...');cycleTimeout2=setTimeout(function(){if(!running)return;var completeBtn=[...app.querySelectorAll('*')].find(function(el){return el.innerText&&el.innerText.trim()==='Complete question';});if(completeBtn){completeBtn.click();log('Clicked: Complete question');}setStatus('Running...');runCycle();},2000);},3000);}function start(){if(running)return;running=true;toggleBtn.textContent='Stop';setStatus('Running...');log('Started');runCycle();intervalId=setInterval(function(){var nextBtn=[...document.querySelectorAll('button')].find(function(el){return el.innerText&&el.innerText.trim()==='Next';});if(nextBtn){nextBtn.click();log('Clicked: Next');}},3000);}function stop(){running=false;toggleBtn.textContent='Start';setStatus('Idle');clearTimeout(cycleTimeout1);clearTimeout(cycleTimeout2);clearInterval(intervalId);log('Stopped');}toggleBtn.addEventListener('click',function(){running?stop():start();});closeBtn.addEventListener('click',function(){stop();panel.remove();window.AutoCycleLoaded=false;});})();
