javascript:(function(){const INTERVAL=500;function isAdPlaying(){return!!(document.querySelector('[data-testid="ad-label"]')||document.querySelector('.ad-banner-container')||document.querySelector('[aria-label="Advertisement"]')||document.querySelector('[data-testid="banner-ad"]')||document.querySelector('.sponsor-container'));}function getPlayer(){return document.querySelector('audio');}function skipCurrentAd(){const audio=getPlayer();if(!audio)return;if(isAdPlaying()){audio.muted=true;audio.playbackRate=16;const adCheck=setInterval(()=>{if(!isAdPlaying()){audio.playbackRate=1;audio.muted=false;clearInterval(adCheck);}},300);}else{audio.muted=false;audio.playbackRate=1;}}function removeAdBanners(){['[data-testid="banner-ad"]','.ad-banner-container','.sponsor-container','[data-testid="ad-label"]','[aria-label="Advertisement"]','.ad-slot','.AdContainer'].forEach(sel=>{document.querySelectorAll(sel).forEach(el=>el.remove());});}function patchAudioApi(){const audio=getPlayer();if(!audio||audio.__axiomPatched)return;const origPlay=audio.play.bind(audio);audio.play=function(){if(isAdPlaying()){audio.muted=true;audio.playbackRate=16;}return origPlay();};audio.__axiomPatched=true;}function injectCSS(){if(document.getElementById('axiom-spotify'))return;const style=document.createElement('style');style.id='axiom-spotify';style.textContent='[data-testid="banner-ad"],.ad-banner-container,.sponsor-container,[aria-label="Advertisement"],[class*="AdContainer"]{display:none!important;height:0!important;overflow:hidden!important;}';document.head.appendChild(style);}const obs=new MutationObserver(()=>{removeAdBanners();skipCurrentAd();patchAudioApi();});obs.observe(document.body,{childList:true,subtree:true});injectCSS();removeAdBanners();patchAudioApi();skipCurrentAd();setInterval(()=>{skipCurrentAd();removeAdBanners();},INTERVAL);console.log('[Axiom] Spotify ads are cooked.');})();
