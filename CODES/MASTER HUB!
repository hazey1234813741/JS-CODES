javascript:(()=>{if(document.getElementById('zertz-hub-container'))return;const style=document.createElement('style');style.id='zertz-hub-styles';style.textContent=':root{--zh-bg:rgba(12,10,24,0.92);--zh-accent:#9d4edd;--zh-accent-2:#00b4d8;--zh-text:#eceff1;--zh-width:320px;--zh-border:rgba(255,255,255,0.08)}#zertz-hub-toggle{position:fixed;bottom:24px;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--zh-accent-2),var(--zh-accent));color:#fff;border:none;cursor:pointer;font-size:26px;font-weight:900;font-family:system-ui,sans-serif;box-shadow:0 8px 24px rgba(157,78,221,0.4);z-index:2147483647;transition:transform 0.2s cubic-bezier(0.175,0.885,0.32,1.275);will-change:transform;display:flex;align-items:center;justify-content:center;text-shadow:0 2px 4px rgba(0,0,0,0.3)}#zertz-hub-toggle:hover{transform:scale(1.1) translateY(-2px);box-shadow:0 12px 28px rgba(0,180,216,0.5)}#zertz-hub-container.zh-right #zertz-hub-toggle{right:24px}#zertz-hub-container.zh-left #zertz-hub-toggle{left:24px}#zertz-hub-sidebar{position:fixed;top:0;bottom:0;width:var(--zh-width);background:var(--zh-bg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);color:var(--zh-text);font-family:system-ui,-apple-system,sans-serif;box-shadow:0 0 40px rgba(0,0,0,0.6);z-index:2147483646;display:flex;flex-direction:column;will-change:transform;transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);border-left:1px solid var(--zh-border)}#zertz-hub-container.zh-right #zertz-hub-sidebar{right:0;transform:translateX(100%)}#zertz-hub-container.zh-left #zertz-hub-sidebar{left:0;transform:translateX(-100%);border-left:none;border-right:1px solid var(--zh-border)}#zertz-hub-container.zh-right.zh-open #zertz-hub-sidebar,#zertz-hub-container.zh-left.zh-open #zertz-hub-sidebar{transform:translateX(0)}.zh-header{padding:20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--zh-border);background:rgba(0,0,0,0.2)}.zh-header h2{margin:0;font-size:1.1rem;font-weight:700;letter-spacing:0.5px;color:#fff;text-transform:uppercase;background:linear-gradient(90deg,var(--zh-accent-2),var(--zh-accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent}.zh-header-actions{display:flex;gap:8px}.zh-icon-btn{background:transparent;border:none;color:#90a4ae;cursor:pointer;font-size:1.2rem;transition:transform 0.2s,color 0.2s;display:flex;padding:4px;border-radius:4px}.zh-icon-btn:hover{transform:rotate(90deg);color:var(--zh-accent-2);background:rgba(255,255,255,0.05)}.zh-icon-btn.zh-delete-btn:hover{color:#ff5252;transform:scale(1.1)}#zh-search-container{padding:12px 20px;border-bottom:1px solid var(--zh-border);background:rgba(0,0,0,0.1)}#zh-search{width:100%;box-sizing:border-box;padding:8px 12px;border-radius:6px;border:1px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.3);color:white;outline:none;font-family:inherit;font-size:0.9rem;transition:all 0.2s}#zh-search::placeholder{color:#78909c}#zh-search:focus{border-color:var(--zh-accent-2);box-shadow:0 0 8px rgba(0,180,216,0.3)}#zh-settings-panel{padding:16px 20px;background:rgba(0,0,0,0.2);border-bottom:1px solid var(--zh-border);display:none;font-size:0.9rem}#zh-settings-panel.zh-active{display:block}#zh-side-select{background:rgba(255,255,255,0.05);color:white;border:1px solid var(--zh-border);padding:6px 12px;border-radius:6px;margin-left:12px;outline:none;cursor:pointer}#zh-script-list{list-style:none;padding:8px 0;margin:0;overflow-y:auto;flex-grow:1}#zh-script-list li{padding:12px 20px;transition:all 0.2s ease;font-size:0.9rem;color:#cfd8dc;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,0.02)}#zh-script-list li:hover{background:rgba(157,78,221,0.08)}.zh-file-info{display:flex;flex-direction:column;flex-grow:1;overflow:hidden}.zh-file-name{font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff}.zh-file-path{font-size:0.75rem;color:#90a4ae;opacity:0.8}.zh-run-btn{margin-left:auto;background:rgba(0,180,216,0.1);color:var(--zh-accent-2);border:1px solid rgba(0,180,216,0.3);padding:6px 10px;border-radius:4px;cursor:pointer;font-size:0.75rem;font-weight:bold;transition:all 0.2s;white-space:nowrap}.zh-run-btn:hover{background:linear-gradient(90deg,var(--zh-accent-2),var(--zh-accent));color:#fff;border-color:transparent;box-shadow:0 0 10px rgba(157,78,221,0.4);transform:scale(1.05)}#zh-console{padding:14px 20px;background:rgba(0,0,0,0.5);color:var(--zh-accent-2);font-family:monospace;font-size:0.85rem;min-height:40px;border-top:1px solid var(--zh-border);display:flex;align-items:center}#zh-script-list::-webkit-scrollbar{width:6px}#zh-script-list::-webkit-scrollbar-track{background:transparent}#zh-script-list::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px}#zh-script-list::-webkit-scrollbar-thumb:hover{background:var(--zh-accent)}';document.head.appendChild(style);const container=document.createElement('div');container.id='zertz-hub-container';const toggleBtn=document.createElement('button');toggleBtn.id='zertz-hub-toggle';toggleBtn.title='Toggle JS Hub (Ctrl+B)';toggleBtn.textContent='Z';container.appendChild(toggleBtn);const sidebar=document.createElement('aside');sidebar.id='zertz-hub-sidebar';const header=document.createElement('div');header.className='zh-header';const title=document.createElement('h2');title.textContent='JS Toolbox';const headerActions=document.createElement('div');headerActions.className='zh-header-actions';const settingsBtn=document.createElement('button');settingsBtn.id='zh-settings-btn';settingsBtn.className='zh-icon-btn';settingsBtn.textContent='⚙️';const deleteBtn=document.createElement('button');deleteBtn.className='zh-icon-btn zh-delete-btn';deleteBtn.title='Delete GUI';deleteBtn.textContent='❌';headerActions.appendChild(settingsBtn);headerActions.appendChild(deleteBtn);header.appendChild(title);header.appendChild(headerActions);sidebar.appendChild(header);const searchContainer=document.createElement('div');searchContainer.id='zh-search-container';const searchInput=document.createElement('input');searchInput.type='text';searchInput.id='zh-search';searchInput.placeholder='Search scripts...';searchContainer.appendChild(searchInput);const settingsPanel=document.createElement('div');settingsPanel.id='zh-settings-panel';const label=document.createElement('label');label.textContent='GUI Side: ';const sideSelect=document.createElement('select');sideSelect.id='zh-side-select';['right','left'].forEach(side=>{const opt=document.createElement('option');opt.value=side;opt.textContent=side.charAt(0).toUpperCase()+side.slice(1);sideSelect.appendChild(opt);});label.appendChild(sideSelect);settingsPanel.appendChild(label);sidebar.appendChild(settingsPanel);sidebar.appendChild(searchContainer);const scriptList=document.createElement('ul');scriptList.id='zh-script-list';sidebar.appendChild(scriptList);const logConsole=document.createElement('div');logConsole.id='zh-console';logConsole.textContent='> Ready.';sidebar.appendChild(logConsole);container.appendChild(sidebar);document.body.appendChild(container);const GITHUB_REPO='TT-ZERTZ/JS-TOOLBOX';const API_URL=`https://api.github.com/repos/${GITHUB_REPO}/git/trees/main?recursive=1`;const RAW_BASE=`https://raw.githubusercontent.com/${GITHUB_REPO}/main/`;const savedSide=localStorage.getItem('zh-hub-side')||'right';container.classList.add('zh-'+savedSide);sideSelect.value=savedSide;sideSelect.addEventListener('change',(e)=>{container.classList.remove('zh-right','zh-left');container.classList.add('zh-'+e.target.value);localStorage.setItem('zh-hub-side',e.target.value);});const toggleHub=()=>container.classList.toggle('zh-open');toggleBtn.addEventListener('click',toggleHub);settingsBtn.addEventListener('click',()=>settingsPanel.classList.toggle('zh-active'));deleteBtn.addEventListener('click',()=>{container.remove();style.remove();});document.addEventListener('keydown',(e)=>{if((e.ctrlKey||e.metaKey)&&e.key.toLowerCase()==='b'){if(document.getElementById('zertz-hub-container')){e.preventDefault();toggleHub();}}});searchInput.addEventListener('input',(e)=>{const term=e.target.value.toLowerCase();const items=scriptList.querySelectorAll('li');items.forEach(li=>{if(li.style.pointerEvents==='none')return;const nameSpan=li.querySelector('.zh-file-name');if(!nameSpan)return;const fileName=nameSpan.textContent.toLowerCase();if(fileName.includes(term)){li.style.display='flex';}else{li.style.display='none';}});});function logMsg(msg){logConsole.textContent='> '+msg;}function setListMessage(msg,color='inherit'){scriptList.textContent='';const li=document.createElement('li');li.textContent=msg;li.style.color=color;li.style.pointerEvents='none';scriptList.appendChild(li);}async function fetchScripts(){try{setListMessage('Scanning subfolders...','#90a4ae');const cacheKey='zh_repo_tree_v5_'+GITHUB_REPO;let treeData=JSON.parse(localStorage.getItem(cacheKey));const cacheTime=localStorage.getItem(cacheKey+'_time');if(!treeData||!cacheTime||Date.now()-parseInt(cacheTime)>3600000){logMsg('Syncing fresh repo data...');let res=await fetch(API_URL);if(!res.ok){const fallbackUrl=`https://api.github.com/repos/${GITHUB_REPO}/git/trees/master?recursive=1`;res=await fetch(fallbackUrl);}if(!res.ok)throw new Error('API blocked');const data=await res.json();treeData=data.tree;localStorage.setItem(cacheKey,JSON.stringify(treeData));localStorage.setItem(cacheKey+'_time',Date.now());}const ignoredExtensions=['.md','.ico','.png','.jpg','.html','.css'];const executableFiles=treeData.filter(item=>{if(item.type!=='blob')return false;const lowerPath=item.path.toLowerCase();return!ignoredExtensions.some(ext=>lowerPath.endsWith(ext));});renderList(executableFiles);logMsg('Scripts synced successfully.');}catch(err){logMsg('Network blocked by site security.');const fallback=JSON.parse(localStorage.getItem('zh_repo_tree_v5_'+GITHUB_REPO));if(fallback){const ignoredExtensions=['.md','.ico','.png','.jpg','.html','.css'];renderList(fallback.filter(item=>item.type==='blob'&&!ignoredExtensions.some(ext=>item.path.toLowerCase().endsWith(ext))));}else{setListMessage('Fetch blocked by site security.','#ff5252');}}}function renderList(files){scriptList.textContent='';if(!files||files.length===0){setListMessage('No executable scripts found.','#ffb74d');return;}files.forEach(file=>{const li=document.createElement('li');const pathParts=file.path.split('/');const fileName=pathParts.pop();const folderPath=pathParts.join('/');const infoDiv=document.createElement('div');infoDiv.className='zh-file-info';const nameSpan=document.createElement('span');nameSpan.className='zh-file-name';nameSpan.textContent=fileName;infoDiv.appendChild(nameSpan);if(folderPath){const pathSpan=document.createElement('span');pathSpan.className='zh-file-path';pathSpan.textContent='📂 '+folderPath;infoDiv.appendChild(pathSpan);}li.appendChild(infoDiv);const runBtn=document.createElement('button');runBtn.className='zh-run-btn';runBtn.textContent='▶ RUN';const downloadUrl=RAW_BASE+file.path;runBtn.addEventListener('click',()=>lazyLoadScript(fileName,downloadUrl));li.appendChild(runBtn);scriptList.appendChild(li);});}async function lazyLoadScript(name,url){try{logMsg('Loading '+name+'...');const cache=await caches.open('js-toolbox-v7');let response=await cache.match(url);if(!response){response=await fetch(url);if(!response.ok)throw new Error('Network error');cache.put(url,response.clone());}let code=await response.text();executeScript(name,code);}catch(err){logMsg('Error loading '+name);}}function executeScript(name,code){try{code=code.replace(/(%[0-9A-F]{2})+/gi,match=>{try{return decodeURIComponent(match);}catch(e){return match;}});const script=document.createElement('script');script.textContent="(()=>{try{\n"+code+"\n}catch(e){console.error('["+name+"] Error:',e);}})();";document.body.appendChild(script);logMsg('Executed: '+name);}catch(err){logMsg('Failed to inject '+name);}}fetchScripts();})();
