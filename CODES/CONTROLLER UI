javascript:(function(){alert("This is my Controller overlay! Press = to delete the GUI, press p to hide/show the gui! press , to cycle modes and finally, press . to change the size of the GUI. thanks! ");if(document.getElementById("fpvOverlay"))return;let wrap=document.createElement("div");wrap.id="fpvOverlay";wrap.style="position:fixed;bottom:30px;left:50%;transform:translateX(-50%);z-index:999999;font-family:sans-serif;color:white;";let mode=0,size=0;const S=[0.75,0.95,1.2];function box(s){let d=document.createElement("div");d.style=s;return d;}let shell=box("width:520px;height:260px;background:transparent;position:relative;padding:20px;");function stick(label){let b=box("width:110px;height:110px;border-radius:50%;position:relative;background:rgba(0,0,0,0.22);");let ring=box("position:absolute;inset:0;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,0.35);");let h=box("position:absolute;top:50%;left:0;width:100%;height:2px;background:rgba(255,255,255,0.35);transform:translateY(-50%);");let v=box("position:absolute;left:50%;top:0;width:2px;height:100%;background:rgba(255,255,255,0.35);transform:translateX(-50%);");let d=box("width:12px;height:12px;background:red;border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);");let t=box("position:absolute;bottom:6px;left:50%;transform:translateX(-50%);font-size:10px;color:rgba(255,255,255,0.6);");t.innerText=label;b.append(ring,h,v,d,t);return{box:b,dot:d,ring};}function btn(t){let d=box("width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:6px;font-size:12px;background:rgba(0,0,0,0.18);opacity:0;transition:0.08s;");d.innerText=t;return d;}function trig(t){let d=box("width:70px;height:85px;display:flex;align-items:center;justify-content:center;border-radius:10px;font-size:11px;background:rgba(0,0,0,0.18);opacity:0;transition:0.08s;");d.innerText=t;return d;}let top=box("display:flex;justify-content:space-between;align-items:center;width:460px;margin:auto;");let LB=trig("LB"),RB=trig("RB"),LT=trig("LT"),RT=trig("RT");top.append(LB,LT,RT,RB);let mid=box("display:flex;justify-content:space-between;align-items:center;width:460px;margin:25px auto 0;");let dpad=box("display:grid;grid-template-columns:repeat(3,30px);gap:4px;");let U=btn("↑"),L=btn("←"),C=box("width:30px;height:30px;"),R=btn("→"),D=btn("↓");C.style="width:30px;height:30px;opacity:0;transition:0.08s;";dpad.append(C,U,C,L,C,R,C,D,C);let left=stick("LS"),right=stick("RS");let abxy=box("display:grid;grid-template-columns:repeat(2,30px);gap:5px;");let A=btn("A"),B=btn("B"),X=btn("X"),Y=btn("Y");abxy.append(X,Y,A,B);mid.append(dpad,left.box,right.box,abxy);shell.append(top,mid);wrap.append(shell);document.body.appendChild(wrap);function apply(){wrap.style.transform="translateX(-50%) scale("+S[size]+")";}apply();function gp(){return navigator.getGamepads?navigator.getGamepads().find(g=>g):null;}function show(e,on){e.style.opacity=on?"1":"0";}function upd(){let g=gp();if(g){let mv=(d,x,y)=>{let r=40;d.style.left=50+x*r+"%";d.style.top=50+y*r+"%";};mv(left.dot,g.axes[0]||0,g.axes[1]||0);mv(right.dot,g.axes[2]||0,g.axes[3]||0);let ls=g.buttons[10]?.pressed,rs=g.buttons[11]?.pressed;left.ring.style.boxShadow=ls?"inset 0 0 0 2px rgba(255,60,60,0.9),0 0 10px rgba(255,60,60,0.6)":"inset 0 0 0 2px rgba(255,255,255,0.35)";right.ring.style.boxShadow=rs?"inset 0 0 0 2px rgba(255,60,60,0.9),0 0 10px rgba(255,60,60,0.6)":"inset 0 0 0 2px rgba(255,255,255,0.35)";let lb=g.buttons[4]?.pressed,rb=g.buttons[5]?.pressed,lt=g.buttons[6]?.value||0,rt=g.buttons[7]?.value||0;if(mode===0){LT.innerText="LT "+Math.round(lt*100)+"%";RT.innerText="RT "+Math.round(rt*100)+"%";}else{LT.innerText="LT";RT.innerText="RT";}show(LB,lb);show(RB,rb);show(LT,lt>0.05);show(RT,rt>0.05);let m=[g.buttons[0],g.buttons[1],g.buttons[2],g.buttons[3],g.buttons[12],g.buttons[13],g.buttons[14],g.buttons[15]];let a=[A,B,X,Y,U,D,L,R];a.forEach((e,i)=>show(e,m[i]?.pressed));}requestAnimationFrame(upd);}upd();document.addEventListener("keydown",e=>{if(e.key==="=")wrap.remove();if(e.key==="p")wrap.style.display=wrap.style.display==="none"?"block":"none";if(e.key===",")mode=1-mode;if(e.key==="."){size=(size+1)%3;apply();}});})()
