javascript:(function(){if(document.getElementById("imageInputUI"))return;let enabled=false,selecting=false,resetting=false,minimized=false,currentURL="";const imageMap=new Map();const ui=document.createElement("div");ui.id="imageInputUI";ui.style="position:fixed;top:100px;left:100px;width:270px;background:#1a1a1a;color:#fff;font-family:sans-serif;border:2px solid #555;border-radius:10px;z-index:999999;box-shadow:0 0 15px rgba(0,0,0,0.7);";const header=document.createElement("div");header.style="padding:8px;cursor:move;background:#2a2a2a;border-bottom:1px solid #555;border-radius:8px 8px 0 0;font-weight:bold;display:flex;justify-content:space-between;align-items:center;";const title=document.createElement("span");title.textContent="ImageInput";const btnWrap=document.createElement("div");const minBtn=document.createElement("button");minBtn.textContent="—";minBtn.style="margin-right:4px;background:#555;color:#fff;border:none;border-radius:5px;cursor:pointer;padding:2px 6px;";const closeBtn=document.createElement("button");closeBtn.textContent="X";closeBtn.style="background:#ff3b30;color:#fff;border:none;border-radius:5px;cursor:pointer;padding:2px 6px;";btnWrap.appendChild(minBtn);btnWrap.appendChild(closeBtn);header.appendChild(title);header.appendChild(btnWrap);const content=document.createElement("div");content.style="padding:10px;";const input=document.createElement("input");input.type="text";input.placeholder="Paste image URL...";input.style="width:100%;padding:6px;margin-bottom:6px;border-radius:6px;border:1px solid #666;background:#000;color:#fff;";const fileInput=document.createElement("input");fileInput.type="file";fileInput.accept="image/*";fileInput.style="width:100%;margin-bottom:6px;color:#fff;";function makeBtn(t,b){const x=document.createElement("button");x.textContent=t;x.style="width:100%;padding:7px;margin-bottom:5px;border:none;border-radius:6px;cursor:pointer;background:"+b+";color:white;font-weight:bold;";return x;}const selectBtn=makeBtn("Select Image","#34c759");const resetBtn=makeBtn("Reset Image","#ff9500");const toggleBtn=makeBtn("Enable","#0a84ff");const status=document.createElement("div");status.textContent="Disabled";status.style="font-size:12px;text-align:center;color:#aaa;";content.append(input,fileInput,selectBtn,resetBtn,toggleBtn,status);ui.append(header,content);document.body.appendChild(ui);let drag=false,ox=0,oy=0;header.onmousedown=e=>{drag=true;ox=e.clientX-ui.offsetLeft;oy=e.clientY-ui.offsetTop;};document.addEventListener("mousemove",e=>{if(!drag)return;ui.style.left=e.clientX-ox+"px";ui.style.top=e.clientY-oy+"px";});document.addEventListener("mouseup",()=>drag=false);minBtn.onclick=()=>{minimized=!minimized;content.style.display=minimized?"none":"block";minBtn.textContent=minimized?"+":"—";};fileInput.onchange=()=>{const f=fileInput.files[0];if(!f)return;const r=new FileReader();r.onload=e=>{currentURL=e.target.result;input.value="(Loaded from file)";status.textContent="Loaded from file";status.style.color="#34c759";};r.readAsDataURL(f);};selectBtn.onclick=()=>{if(!enabled){status.textContent="Enable first!";status.style.color="#ffcc00";return;}const u=currentURL||input.value.trim();if(!u){status.textContent="Enter URL/file!";status.style.color="#ffcc00";return;}currentURL=u;selecting=true;resetting=false;status.textContent="Click image...";status.style.color="#34c759";};resetBtn.onclick=()=>{if(!enabled){status.textContent="Enable first!";status.style.color="#ffcc00";return;}resetting=true;selecting=false;status.textContent="Click image to reset...";status.style.color="#ff9500";};function clickHandler(e){if(!enabled)return;const img=e.target.closest("img");if(!img)return;if(selecting){e.preventDefault();e.stopPropagation();if(!imageMap.has(img)){imageMap.set(img,{original:img.src,replaced:currentURL});}else{imageMap.get(img).replaced=currentURL;}img.src=currentURL;selecting=false;status.textContent="Replaced!";status.style.color="#0a84ff";}if(resetting){e.preventDefault();e.stopPropagation();if(imageMap.has(img)){img.src=imageMap.get(img).original;imageMap.delete(img);status.textContent="Reset!";status.style.color="#ff9500";}resetting=false;}}document.addEventListener("click",clickHandler,true);toggleBtn.onclick=()=>{enabled=!enabled;if(enabled){toggleBtn.textContent="Disable";toggleBtn.style.background="#ff3b30";status.textContent="Enabled";status.style.color="#34c759";imageMap.forEach((d,img)=>img.src=d.replaced);}else{toggleBtn.textContent="Enable";toggleBtn.style.background="#0a84ff";status.textContent="Disabled";status.style.color="#aaa";selecting=false;resetting=false;imageMap.forEach((d,img)=>img.src=d.original);}};closeBtn.onclick=()=>{imageMap.forEach((d,img)=>img.src=d.original);document.removeEventListener("click",clickHandler,true);ui.remove();};})();
